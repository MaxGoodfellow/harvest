{
  "name": "harvest",
  "version": "1.0.0",
  "description": "PF2e Harvesting Manager",
  "private": true,
  "main": "src/server.js",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:create": "node src/db/create.js",
    "db:migrate": "node src/db/migrate.js",
    "db:seed": "node src/db/seed.js",
    "db:reset": "npm run db:create && npm run db:migrate && npm run db:seed",
    "db:backup": "node src/db/backup.js",
    "db:restore": "node src/db/restore.js",
    "test": "node --test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "auth:hash": "node src/scripts/hashPassword.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.21.1",
    "express-ejs-layouts": "^2.5.1",
    "express-rate-limit": "^7.4.1",
    "express-session": "^1.18.1",
    "helmet": "^7.2.0",
    "mysql2": "^3.11.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "nodemon": "^3.1.7",
    "prettier": "^3.3.3"
  }
}
